# Только для локальной разработки. Не использовать эти значения в production.

APP_PORT=8088
BACKEND_PORT=8080
GATEWAY_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
REDIS_PORT=6379
LIVEKIT_HTTP_PORT=7880
LIVEKIT_TCP_PORT=7881
LIVEKIT_UDP_PORT_START=50000
LIVEKIT_UDP_PORT_END=50100
LIVEKIT_BIND_ADDRESS=127.0.0.1
LIVEKIT_NODE_IP=127.0.0.1

POSTGRES_DB=watch_together
POSTGRES_USER=watch_together
POSTGRES_PASSWORD=watch_together_dev_only

REDIS_PASSWORD=watch_together_redis_dev_only
ROOM_TTL=4h
SESSION_COOKIE_SECURE=false

LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdevsecret
LIVEKIT_URL=ws://127.0.0.1:7880
PUBLIC_LIVEKIT_URL=ws://127.0.0.1:7880

# WT-605 feedback operations. Operator endpoints (list/export/triage) stay disabled
# while the token is empty; set a real secret on beta to enable them.
FEEDBACK_ADMIN_TOKEN=
FEEDBACK_RETENTION=30d

# WT-606 gateway CSP connect-src (default "'self' ws: wss:" when unset). Narrow in
# production to the fixed beta host(s), e.g.:
# WT_CSP_CONNECT_SRC='self' wss://<livekit-public-host>
# Rate limiting (WT-606) is on by default; RATE_LIMIT_* overrides live in application.yml.
