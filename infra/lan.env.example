# Private home LAN only. Copy to infra/lan.env and replace 192.168.1.42 with
# the current private IPv4 address of the MacBook that runs Docker.
#
# Do not use this file with port forwarding, a public IP, a VPN exit node, or a
# cloud VM. It intentionally has no TLS, public TURN, secure cookies, or
# production secrets. Keep the normal infra/compose.yaml defaults for every
# value not listed here.

GATEWAY_BIND_ADDRESS=0.0.0.0
LIVEKIT_BIND_ADDRESS=0.0.0.0
LIVEKIT_NODE_IP=192.168.1.42
# The backend returns this URL in the minted LiveKit token response; it must
# point at the MacBook from the Windows browser, never at the guest's loopback.
LIVEKIT_URL=ws://192.168.1.42:7880
PUBLIC_LIVEKIT_URL=ws://192.168.1.42:7880
