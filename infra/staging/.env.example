# Copy to a protected file outside git, for example /opt/watch-together/.env.
# Values below are placeholders only. Generate real LiveKit and Redis values with
# the official LiveKit production generator; never reuse its sample output.

WT_STAGING_APP_DOMAIN=app.staging.example.com
WT_STAGING_RTC_DOMAIN=rtc.staging.example.com

# Must match the Redis password generated for the LiveKit stack. Watch Together
# uses Redis database 1; LiveKit keeps its own state in database 0.
LIVEKIT_REDIS_PASSWORD=replace-with-a-real-secret
LIVEKIT_API_KEY=replace-with-livekit-api-key
LIVEKIT_API_SECRET=replace-with-livekit-api-secret
FEEDBACK_ADMIN_TOKEN=replace-with-a-separate-long-random-secret

FEEDBACK_RETENTION=30d
FEEDBACK_EXPORT_LIMIT=200
ROOM_TTL=4h
ROOM_CLEANUP_GRACE=5m
LIVEKIT_TOKEN_TTL=10m
