{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://watch-together.local/contracts/schemas/websocket-client-event.schema.json",
  "title": "Client WebSocket event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "type",
    "roomId",
    "participantId",
    "expectedRoomVersion",
    "occurredAt",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "type": {
      "type": "string",
      "enum": [
        "participant.ready",
        "participant.heartbeat",
        "host.media.selected",
        "host.play",
        "host.pause",
        "host.seek",
        "host.media.started",
        "host.media.stopped",
        "chat.message"
      ]
    },
    "roomId": {
      "$ref": "https://watch-together.local/contracts/schemas/common.schema.json#/$defs/RoomId"
    },
    "participantId": {
      "$ref": "https://watch-together.local/contracts/schemas/common.schema.json#/$defs/ParticipantId"
    },
    "expectedRoomVersion": {
      "type": "integer",
      "minimum": 0
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "enum": ["participant.ready", "participant.heartbeat"]
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sentAt"],
            "properties": {
              "sentAt": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "host.media.selected"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["displayName", "durationMs"],
            "properties": {
              "displayName": {
                "type": "string",
                "minLength": 1,
                "maxLength": 128
              },
              "durationMs": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "host.play",
              "host.pause",
              "host.seek",
              "host.media.started"
            ]
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["positionMs"],
            "properties": {
              "positionMs": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "host.media.stopped"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["positionMs", "reason"],
            "properties": {
              "positionMs": {
                "type": "integer",
                "minimum": 0
              },
              "reason": {
                "type": "string",
                "enum": ["ENDED", "REPLACED", "HOST_ACTION"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "chat.message"
          }
        },
        "required": ["type"]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["clientMessageId", "text"],
            "properties": {
              "clientMessageId": {
                "type": "string",
                "format": "uuid"
              },
              "text": {
                "type": "string",
                "minLength": 1,
                "maxLength": 1000
              }
            }
          }
        }
      }
    }
  ]
}
